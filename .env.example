# ================================================================
# NexusCare backend — environment variable template
#
# Copy this file to a real ".env" and fill in actual values.
#
# IMPORTANT — file location: the app loads ".env" from this directory,
# the REPOSITORY ROOT (C:\NexusCare\.env). See _ENV_FILE in
# backend/app/config.py. Copy this template to ".env" right here.
#
# Never commit the real .env — it holds secrets. This .example file
# contains placeholders only.
# ================================================================

# --- Database (PostgreSQL) ---
# Individual connection parts. Required — no defaults.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_care
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Full async SQLAlchemy DSN used by the engine. Required.
# Must use the asyncpg driver (postgresql+asyncpg://...).
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/nexus_care

# --- Security / JWT ---
# Secret used to sign JWTs. MUST be a long, random string in production.
SECRET_KEY=replace-with-a-long-random-secret

# JWT signing algorithm. Default: HS256.
ALGORITHM=HS256

# Access token lifetime, in minutes. Default: 480 (8 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Workspace-selection token lifetime, in minutes. Default: 5.
SELECTION_TOKEN_EXPIRE_MINUTES=5

# Invite token lifetime, in minutes. Default: 10080 (7 days).
INVITE_TOKEN_EXPIRE_MINUTES=10080

# Password-reset token lifetime, in minutes. Default: 60 (1 hour).
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of origins allowed to call this API from a
# browser. The dev default covers React (3000) + Vite (5173).
# Production: set a strict whitelist of real frontend hostnames,
# e.g. https://app.nexuscare.com — never use "*".
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
